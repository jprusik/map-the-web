{
  "ignores": ["node_modules"],
  "config": {
    "default": true,
    // Disabled: Prettier handles line wrapping
    "MD013": false,
    // Allow punctuation in headings (e.g. project title)
    "MD026": false,
    // Allow HTML elements referenced in documentation
    "MD033": {
      "allowed_elements": ["form"],
    },
  },
}
